<%- include("partials/header") %>

<section class="section-block" id="plan-filters">
  <form class="filters-panel" method="get" action="/plan">
    <div class="filters-grid">
      <label class="form-grid__full">
        Search
        <div class="compact-search-form">
          <input type="text" name="search" value="<%= filters.search %>" placeholder="Search places, suburbs, or notes" />
          <button class="button" type="submit">Search</button>
        </div>
      </label>
      <label>
        What day are you dining?
        <select name="day">
          <% dayLabels.forEach((dayLabel, dayIndex) => { %>
            <option value="<%= dayIndex %>" <%= filters.day === dayIndex ? "selected" : "" %>><%= dayLabel %></option>
          <% }) %>
        </select>
      </label>
      <div>
        <span class="form-label">What time?</span>
        <input type="hidden" name="meal" id="plan-meal" value="<%= filters.meal %>" />
        <div class="meal-choice-group">
          <button class="button <%= filters.meal === "breakfast" ? "" : "button--secondary" %>" type="button" data-plan-meal="breakfast">Breakfast</button>
          <button class="button <%= filters.meal === "lunch" ? "" : "button--secondary" %>" type="button" data-plan-meal="lunch">Lunch</button>
          <button class="button <%= filters.meal === "dinner" ? "" : "button--secondary" %>" type="button" data-plan-meal="dinner">Dinner</button>
        </div>
      </div>
      <input type="hidden" name="lat" id="plan-lat" value="<%= filters.latitude ?? "" %>" />
      <input type="hidden" name="lng" id="plan-lng" value="<%= filters.longitude ?? "" %>" />
    </div>

    <div class="prominent-tag-groups">
      <% if (categoryTagGroup) { %>
        <% const categoryHasSelection = categoryTagGroup.tags.some((tag) => hasSelectedTag(filters, tag.slug)); %>
        <details class="tag-filter-collapse" <%= categoryHasSelection ? "open" : "" %>>
          <summary class="tag-filter-collapse__summary">Occasion</summary>
          <fieldset class="tag-filter-group tag-filter-group--prominent">
            <div class="tag-filter-list">
              <% categoryTagGroup.tags.forEach((tag) => { %>
                <label class="tag-checkbox">
                  <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
                  <span><%= tag.name %></span>
                </label>
              <% }) %>
            </div>
          </fieldset>
        </details>
      <% } %>

      <% if (menuTagGroup) { %>
        <% const menuHasSelection = menuTagGroup.tags.some((tag) => hasSelectedTag(filters, tag.slug)); %>
        <details class="tag-filter-collapse" <%= menuHasSelection ? "open" : "" %>>
          <summary class="tag-filter-collapse__summary">Food</summary>
          <fieldset class="tag-filter-group tag-filter-group--prominent">
            <div class="tag-filter-list">
              <% menuTagGroup.tags.forEach((tag) => { %>
                <label class="tag-checkbox">
                  <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
                  <span><%= tag.name %></span>
                </label>
              <% }) %>
            </div>
          </fieldset>
        </details>
      <% } %>

      <% if (glutenTagGroup) { %>
        <% const glutenHasSelection = glutenTagGroup.tags.some((tag) => hasSelectedTag(filters, tag.slug)); %>
        <details class="tag-filter-collapse" <%= glutenHasSelection ? "open" : "" %>>
          <summary class="tag-filter-collapse__summary">GF support</summary>
          <fieldset class="tag-filter-group tag-filter-group--prominent">
            <div class="tag-filter-list">
              <% glutenTagGroup.tags.forEach((tag) => { %>
                <label class="tag-checkbox">
                  <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
                  <span><%= tag.name %></span>
                </label>
              <% }) %>
            </div>
          </fieldset>
        </details>
      <% } %>
    </div>

    <fieldset class="tag-filter-group tag-filter-group--prominent">
      <legend>Regular or somewhere new?</legend>
      <div class="tag-filter-list">
        <% planStatusValues.forEach((value) => { %>
          <label class="tag-checkbox">
            <input type="radio" name="status_preference" value="<%= value %>" <%= filters.statusPreference === value ? "checked" : "" %> />
            <span><%= value === "all" ? "Show both" : (value === "trusted" ? "Your regulars" : "Somewhere new") %></span>
          </label>
        <% }) %>
      </div>
    </fieldset>

    <div class="filters-actions">
      <button class="button" type="submit">Find ideas</button>
      <a class="button button--secondary" href="/plan">Show everything</a>
    </div>
  </form>
</section>

<% if (filters.statusPreference !== "want_to_try") { %>
  <section class="section-block" id="plan-results">
    <div class="section-heading section-heading--roomy">
      <div>
        <h2><span class="module-icon module-icon--mint"></span>Your regulars</h2>
      </div>
    </div>

    <% if (trustedPlaces.length) { %>
      <div class="card-grid">
        <% trustedPlaces.forEach((place) => { %>
          <%- include("partials/plan-card", { place, selectedDay: filters.day, showStatusBadge: false }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">No trusted places matched those plan filters.</p>
    <% } %>
  </section>
<% } %>

<% if (filters.statusPreference !== "trusted") { %>
  <section class="section-block" <%= filters.statusPreference === "want_to_try" ? 'id="plan-results"' : "" %>>
    <div class="section-heading section-heading--roomy">
      <div>
        <h2><span class="module-icon module-icon--pink"></span>Somewhere new</h2>
      </div>
    </div>

    <% if (wantToTryPlaces.length) { %>
      <div class="card-grid">
        <% wantToTryPlaces.forEach((place) => { %>
          <%- include("partials/plan-card", { place, selectedDay: filters.day }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">No want-to-try places matched those plan filters.</p>
    <% } %>
  </section>
<% } %>

<script src="/plan.js"></script>

<%- include("partials/footer") %>
