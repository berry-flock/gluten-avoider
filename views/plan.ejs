<%- include("partials/header") %>

<section class="section-block" id="plan-filters">
  <form class="filters-panel" method="get" action="/plan">
    <div class="filters-grid">
      <label class="form-grid__full">
        Search
        <div class="compact-search-form">
          <input type="text" name="search" value="<%= filters.search %>" placeholder="Search places, suburbs, or notes" />
          <button class="button" type="submit">Search</button>
        </div>
      </label>
      <label>
        What day are you dining?
        <select name="day">
          <% dayLabels.forEach((dayLabel, dayIndex) => { %>
            <option value="<%= dayIndex %>" <%= filters.day === dayIndex ? "selected" : "" %>><%= dayLabel %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <% if (categoryTagGroup) { %>
      <fieldset class="tag-filter-group tag-filter-group--prominent">
        <legend>Occasion</legend>
        <div class="tag-filter-list">
          <% categoryTagGroup.tags.forEach((tag) => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
              <span><%= tag.name %></span>
            </label>
          <% }) %>
        </div>
      </fieldset>
    <% } %>

    <% if (menuTagGroup) { %>
      <fieldset class="tag-filter-group tag-filter-group--prominent">
        <legend>Food</legend>
        <div class="tag-filter-list">
          <% menuTagGroup.tags.forEach((tag) => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
              <span><%= tag.name %></span>
            </label>
          <% }) %>
        </div>
      </fieldset>
    <% } %>

    <% if (glutenTagGroup) { %>
      <fieldset class="tag-filter-group tag-filter-group--prominent">
        <legend>GF support</legend>
        <div class="tag-filter-list">
          <% glutenTagGroup.tags.forEach((tag) => { %>
            <label class="tag-checkbox">
              <input type="checkbox" name="tags" value="<%= tag.slug %>" <%= hasSelectedTag(filters, tag.slug) ? "checked" : "" %> />
              <span><%= tag.name %></span>
            </label>
          <% }) %>
        </div>
      </fieldset>
    <% } %>

    <fieldset class="tag-filter-group tag-filter-group--prominent">
      <legend>Regular or somewhere new?</legend>
      <div class="tag-filter-list">
        <% planStatusValues.forEach((value) => { %>
          <label class="tag-checkbox">
            <input type="radio" name="status_preference" value="<%= value %>" <%= filters.statusPreference === value ? "checked" : "" %> />
            <span><%= value === "all" ? "Show both" : (value === "trusted" ? "Your regulars" : "Somewhere new") %></span>
          </label>
        <% }) %>
      </div>
    </fieldset>

    <div class="filters-actions">
      <button class="button" type="submit">Find ideas</button>
      <a class="button button--secondary" href="/plan">Reset</a>
    </div>
  </form>
</section>

<% if (filters.statusPreference !== "want_to_try") { %>
  <section class="section-block" id="plan-results">
    <div class="section-heading section-heading--roomy">
      <div>
        <h2><span class="module-icon module-icon--mint"></span>Your regulars</h2>
      </div>
    </div>

    <% if (trustedPlaces.length) { %>
      <div class="card-grid">
        <% trustedPlaces.forEach((place) => { %>
          <%- include("partials/plan-card", { place, selectedDay: filters.day, showStatusBadge: false }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">No trusted places matched those plan filters.</p>
    <% } %>
  </section>
<% } %>

<% if (filters.statusPreference !== "trusted") { %>
  <section class="section-block">
    <div class="section-heading section-heading--roomy">
      <div>
        <h2><span class="module-icon module-icon--pink"></span>Somewhere new</h2>
      </div>
    </div>

    <% if (wantToTryPlaces.length) { %>
      <div class="card-grid">
        <% wantToTryPlaces.forEach((place) => { %>
          <%- include("partials/plan-card", { place, selectedDay: filters.day }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">No want-to-try places matched those plan filters.</p>
    <% } %>
  </section>
<% } %>

<script src="/plan.js"></script>

<%- include("partials/footer") %>
