<%- include("../../partials/header") %>

<section class="section-block">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Admin tags</p>
      <h1>Manage tags</h1>
    </div>
    <div class="admin-actions">
      <a class="button" href="/admin/tags/new">Add tag</a>
      <a class="button button--secondary" href="/admin">Dashboard</a>
    </div>
  </div>

  <p class="section-copy">Use this page to keep the tag system tidy across the three main groups used in the app.</p>

  <% if (notice) { %>
    <p class="form-message form-message--success"><%= notice %></p>
  <% } %>
  <% if (tagError) { %>
    <p class="form-message form-message--error"><%= tagError %></p>
  <% } %>

  <% groupedTags.forEach((group) => { %>
    <section class="detail-block">
      <div class="section-heading">
        <div>
          <h2><%= group.label %></h2>
          <p class="section-copy"><%= group.question %></p>
        </div>
      </div>

      <% if (group.tags.length) { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Slug</th>
                <th>Used by</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% group.tags.forEach((tag) => { %>
                <tr>
                  <td><strong><%= tag.name %></strong></td>
                  <td><span class="table-subtext"><%= tag.slug %></span></td>
                  <td><%= tag.usage_count %> place<%= tag.usage_count === 1 ? "" : "s" %></td>
                  <td class="admin-table__actions">
                    <a class="text-link" href="/places?tags=<%= encodeURIComponent(tag.slug) %>">View</a>
                    <a class="text-link" href="/admin/tags/<%= tag.id %>/edit">Edit</a>
                    <form method="post" action="/admin/tags/<%= tag.id %>/delete">
                      <button class="button-link-danger" type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="empty-state">No tags in this group yet.</p>
      <% } %>
    </section>
  <% }) %>
</section>

<%- include("../../partials/footer") %>
