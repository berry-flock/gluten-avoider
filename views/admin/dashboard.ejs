<%- include("../partials/header") %>

<section class="section-block">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>Dashboard</h1>
    </div>
    <form method="post" action="/admin/logout">
      <button class="button button--secondary" type="submit">Log out</button>
    </form>
  </div>

  <p class="section-copy">This is the private admin area for managing the notebook. Places and tags can both be managed here.</p>

  <div class="admin-stats-grid">
    <article class="stat-card">
      <h2><%= stats.place_count %></h2>
      <p>Saved places</p>
    </article>
    <article class="stat-card">
      <h2><%= stats.public_place_count %></h2>
      <p>Public places</p>
    </article>
    <article class="stat-card">
      <h2><%= stats.tag_count %></h2>
      <p>Tags</p>
    </article>
  </div>

  <div class="admin-links">
    <a class="button" href="/admin/places">Manage places</a>
    <a class="button" href="/admin/tags">Manage tags</a>
    <a class="button" href="/places">View public browse</a>
  </div>
</section>

<section class="section-block">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Hours reminder</p>
      <h2>Places missing opening hours</h2>
    </div>
  </div>

  <% if (placesMissingOpeningHours.length) { %>
    <ul class="admin-reminder-list">
      <% placesMissingOpeningHours.forEach((place) => { %>
        <li>
          <a class="text-link" href="/admin/places/<%= place.id %>/edit"><%= place.name %></a>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="empty-state">Everything currently has opening hours filled in.</p>
  <% } %>
</section>

<%- include("../partials/footer") %>
