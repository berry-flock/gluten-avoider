<%- include("partials/header") %>

<section class="hero">
  <div class="hero__copy">
    <p class="eyebrow">Personal trusted-places notebook</p>
    <h1>Keep track of the food places you trust.</h1>
    <p class="hero__text">
      This app is built for two simple questions: what is a good option nearby right now, and what is worth keeping in mind for later.
    </p>
    <div class="hero__actions">
      <a class="button" href="/places">Browse all places</a>
      <a class="button button--secondary" href="/nearby">Nearby now</a>
      <a class="button button--secondary" href="/plan">Plan later</a>
      <a class="button button--secondary" href="/map">Map view</a>
      <% if (currentAdmin) { %>
        <a class="button" href="/admin/places/new">Add new place</a>
      <% } %>
    </div>
  </div>
</section>

<% if (currentAdmin) { %>
  <section class="section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Admin shortcuts</p>
        <h2>Add or update places quickly</h2>
      </div>
    </div>
    <div class="admin-actions">
      <a class="button" href="/admin/places/new">Add new place</a>
      <a class="button button--secondary" href="/admin">Open admin dashboard</a>
    </div>
  </section>
<% } %>

<section class="section-block section-block--tag-focus">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Browse by tags</p>
      <h2>Use tags as a fast way to explore.</h2>
    </div>
    <p class="section-copy">Nearby now and plan later will be the main workflows. Tags are the next fastest way to narrow to the right kind of place.</p>
  </div>

  <div class="tag-group-grid">
    <% groupedTags.forEach((group) => { %>
      <section class="tag-group-card">
        <h3><%= group.label %></h3>
        <div class="tag-row">
          <% group.tags.forEach((tag) => { %>
            <a class="tag-pill tag-pill--link tag-pill--large" href="/places?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
          <% }) %>
        </div>
      </section>
    <% }) %>
  </div>
</section>

<section class="section-block">
  <div class="section-heading">
    <h2>Recently updated</h2>
    <a class="text-link" href="/places?sort=recently_updated">See all</a>
  </div>

  <% if (recentPlaces.length) { %>
    <div class="card-grid">
      <% recentPlaces.forEach((place) => { %>
        <%- include("partials/place-card", { place }) %>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-state">No places saved yet.</p>
  <% } %>
</section>

<%- include("partials/footer") %>
