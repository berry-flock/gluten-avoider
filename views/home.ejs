<% const assetVersion = "20260405-2"; %>
<% const extraHead = `<link rel="stylesheet" href="/leaflet.css?v=${assetVersion}" />
<style>
  .leaflet-container img.leaflet-tile { mix-blend-mode: normal; }
</style>`; %>
<%- include("partials/header") %>

<section class="section-block home-intro-card">
  <div class="section-heading section-heading--roomy">
    <div>
      <p class="eyebrow">Find safe eats</p>
      <h1>Let's get you fed</h1>
      <p class="section-copy">Use nearby now when you need a quick answer. Use plan later when you are making weekend dinner plans or chasing a craving.</p>
    </div>
    <% if (currentAdmin) { %>
      <a class="button" href="/admin/places/new">Add new restaurant</a>
    <% } %>
  </div>
</section>

<div class="home-module-grid">
  <section class="section-block home-module home-module--nearby">
    <div class="section-heading">
      <h2><a class="module-link" href="/nearby"><span class="module-icon module-icon--pink"></span>Nearby now</a></h2>
    </div>

    <div class="filters-actions nearby-meal-switcher nearby-meal-switcher--home">
      <button class="button <%= defaultNearbyMeal === "open" ? "" : "button--secondary" %>" type="button" data-home-nearby-meal="open">Open</button>
      <button class="button <%= defaultNearbyMeal === "lunch" ? "" : "button--secondary" %>" type="button" data-home-nearby-meal="lunch">Lunch</button>
      <button class="button <%= defaultNearbyMeal === "dinner" ? "" : "button--secondary" %>" type="button" data-home-nearby-meal="dinner">Dinner</button>
    </div>

    <div id="home-nearby-preview">
      <p class="empty-state">Trying to find your location to show the closest trusted places that are open now.</p>
    </div>
  </section>

  <div class="home-module-stack">
    <section class="section-block home-module home-module--plan">
      <div class="section-heading">
        <h2><a class="module-link" href="/plan"><span class="module-icon module-icon--yellow"></span>Plan later</a></h2>
      </div>

      <form class="stack-form home-plan-form" method="get" action="/plan">
        <label>
          Day
          <select name="day">
            <% dayLabels.forEach((dayLabel, dayIndex) => { %>
              <option value="<%= dayIndex %>" <%= dayIndex === defaultPlanDay ? "selected" : "" %>><%= dayLabel %></option>
            <% }) %>
          </select>
        </label>
        <div class="meal-choice-group">
          <input type="hidden" name="meal" value="<%= defaultPlanMeal %>" />
          <button class="button <%= defaultPlanMeal === "breakfast" ? "" : "button--secondary" %>" type="button" data-home-plan-meal="breakfast">Breakfast</button>
          <button class="button <%= defaultPlanMeal === "lunch" ? "" : "button--secondary" %>" type="button" data-home-plan-meal="lunch">Lunch</button>
          <button class="button <%= defaultPlanMeal === "dinner" ? "" : "button--secondary" %>" type="button" data-home-plan-meal="dinner">Dinner</button>
        </div>
        <label class="sr-only" for="home-search">Search places</label>
        <div class="compact-search-form">
          <input id="home-search" type="text" name="search" placeholder="Search places, suburbs, or notes" />
          <button class="button button--secondary" type="submit">Search</button>
        </div>

        <div class="filters-actions">
          <a class="button button--secondary" href="/plan#plan-filters">Search by tags</a>
          <a class="button button--secondary" href="/plan">Show everything</a>
        </div>
      </form>
    </section>

    <section class="section-block home-module home-module--food">
      <div class="section-heading">
        <h2><span class="module-icon module-icon--peach"></span>Food feelings</h2>
        <button class="icon-button" type="button" id="food-feelings-refresh" aria-label="Refresh food feelings">
          <span class="icon-refresh" aria-hidden="true"></span>
        </button>
      </div>
      <div class="tag-row" id="food-feelings-list" data-food-feelings='<%- JSON.stringify(foodFeelingTags || []) %>'></div>
    </section>
  </div>

  <section class="section-block home-module home-module--map">
    <div class="section-heading">
      <h2><a class="module-link" href="/map"><span class="module-icon module-icon--mint"></span>Map view</a></h2>
    </div>

    <div class="filters-actions home-map-controls">
      <% mapAvailabilityValues.forEach((value) => { %>
        <button class="button button--secondary home-map-filter" type="button" data-map-availability="<%= value %>"><%= value %></button>
      <% }) %>
    </div>
    <div class="tag-row home-map-suburbs">
      <% topSuburbs.forEach((suburb) => { %>
        <button class="button button--secondary home-map-suburb" type="button" data-map-suburb="<%= suburb %>"><%= suburb %></button>
      <% }) %>
    </div>
    <div id="home-map" class="nearby-map"></div>
    <p id="home-map-message" class="section-copy">Trying to center the map on your current location.</p>
  </section>
</div>

<script src="/leaflet.js?v=<%= assetVersion %>"></script>
<script src="/home.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer") %>
