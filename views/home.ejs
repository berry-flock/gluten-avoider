<%- include("partials/header") %>

<section class="section-block home-intro-card">
  <div class="section-heading section-heading--roomy">
    <div>
      <p class="eyebrow">Find safe eats</p>
      <h1>Let's get you fed</h1>
      <p class="section-copy">Use nearby now when you need a quick answer. Use plan later when you are making weekend dinner plans or chasing a craving.</p>
    </div>
    <% if (currentAdmin) { %>
      <a class="button" href="/admin/places/new">Add new restaurant</a>
    <% } %>
  </div>
</section>

<div class="home-module-grid">
  <section class="section-block home-module">
    <div class="section-heading">
      <h2><a class="module-link" href="/nearby"><span class="module-icon module-icon--pink"></span>Nearby now</a></h2>
    </div>

    <div id="home-nearby-preview">
      <p class="empty-state">Trying to find your location to show the closest trusted places that are open now.</p>
    </div>
  </section>

  <section class="section-block home-module">
    <div class="section-heading">
      <h2><a class="module-link" href="/plan"><span class="module-icon module-icon--yellow"></span>Plan later</a></h2>
    </div>

    <form class="stack-form" method="get" action="/plan">
      <label class="sr-only" for="home-search">Search places</label>
      <input id="home-search" type="text" name="search" placeholder="Search places, suburbs, or notes" />

      <% if (categoryTagGroup) { %>
        <fieldset class="tag-filter-group tag-filter-group--prominent">
          <legend>Occasion</legend>
          <div class="tag-filter-list">
            <% categoryTagGroup.tags.forEach((tag) => { %>
              <label class="tag-checkbox">
                <input type="checkbox" name="tags" value="<%= tag.slug %>" />
                <span><%= tag.name %></span>
              </label>
            <% }) %>
          </div>
        </fieldset>
      <% } %>

      <% if (menuTagGroup) { %>
        <fieldset class="tag-filter-group tag-filter-group--prominent">
          <legend>Food</legend>
          <div class="tag-filter-list">
            <% menuTagGroup.tags.forEach((tag) => { %>
              <label class="tag-checkbox">
                <input type="checkbox" name="tags" value="<%= tag.slug %>" />
                <span><%= tag.name %></span>
              </label>
            <% }) %>
          </div>
        </fieldset>
      <% } %>

      <div class="filters-actions">
        <button class="button" type="submit">Search</button>
        <a class="button button--secondary" href="/places">Show everything</a>
      </div>
    </form>
  </section>

  <section class="section-block home-module home-module--map">
    <div class="section-heading">
      <h2><a class="module-link" href="/map"><span class="module-icon module-icon--mint"></span>Map view</a></h2>
    </div>

    <div id="home-map" class="nearby-map"></div>
    <p id="home-map-message" class="section-copy">Trying to center the map on your current location.</p>
  </section>
</div>

<section class="section-block home-collections-panel">
  <div class="section-heading">
    <h2><span class="module-icon module-icon--lavender"></span>Collections</h2>
  </div>
  <div class="home-collection-grid home-collection-grid--panel">
    <a class="home-collection-card" href="/plan?status_preference=trusted">
      <span class="eyebrow">Saved</span>
      <h3>Your regulars</h3>
      <p class="section-copy">Go straight to places you already trust.</p>
    </a>
    <a class="home-collection-card" href="/plan?status_preference=want_to_try">
      <span class="eyebrow">Saved</span>
      <h3>Want to try</h3>
      <p class="section-copy">Browse the short list for something new.</p>
    </a>
  </div>
</section>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script src="/home.js"></script>

<%- include("partials/footer") %>
