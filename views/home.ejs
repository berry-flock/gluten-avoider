<%- include("partials/header") %>

<section class="home-header">
  <% if (currentAdmin) { %>
    <a class="button" href="/admin/places/new">Add new restaurant</a>
  <% } %>
</section>

<div class="home-module-grid">
  <section class="section-block home-module">
    <div class="section-heading">
      <h2><a class="module-link" href="/nearby">Nearby now</a></h2>
    </div>

    <div id="home-nearby-preview">
      <p class="empty-state">Trying to find your location to show the closest trusted places that are open now.</p>
    </div>
  </section>

  <section class="section-block home-module">
    <div class="section-heading">
      <h2><a class="module-link" href="/plan">Plan later</a></h2>
    </div>

    <form class="stack-form" method="get" action="/plan">
      <label class="sr-only" for="home-search">Search places</label>
      <input id="home-search" type="text" name="search" placeholder="Search places, suburbs, or notes" />

      <% if (categoryTagGroup) { %>
        <fieldset class="tag-filter-group tag-filter-group--prominent">
          <legend>Occasion</legend>
          <div class="tag-filter-list">
            <% categoryTagGroup.tags.forEach((tag) => { %>
              <label class="tag-checkbox">
                <input type="checkbox" name="tags" value="<%= tag.slug %>" />
                <span><%= tag.name %></span>
              </label>
            <% }) %>
          </div>
        </fieldset>
      <% } %>

      <% if (menuTagGroup) { %>
        <fieldset class="tag-filter-group tag-filter-group--prominent">
          <legend>Food</legend>
          <div class="tag-filter-list">
            <% menuTagGroup.tags.forEach((tag) => { %>
              <label class="tag-checkbox">
                <input type="checkbox" name="tags" value="<%= tag.slug %>" />
                <span><%= tag.name %></span>
              </label>
            <% }) %>
          </div>
        </fieldset>
      <% } %>

      <div class="filters-actions">
        <button class="button" type="submit">Search</button>
        <a class="button button--secondary" href="/places">Show everything</a>
      </div>
    </form>
  </section>

  <section class="section-block home-module home-module--map">
    <div class="section-heading">
      <h2><a class="module-link" href="/map">Map view</a></h2>
    </div>

    <div id="home-map" class="nearby-map"></div>
    <p id="home-map-message" class="section-copy">Trying to center the map on your current location.</p>
  </section>
</div>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script src="/home.js"></script>

<%- include("partials/footer") %>
