<% const extraHead = '<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />'; %>
<%- include("partials/header") %>

<section class="section-block">
  <div class="section-heading section-heading--roomy">
    <div>
      <p class="eyebrow">Map</p>
      <h1><span class="module-icon module-icon--sky"></span>Browse saved places on the map</h1>
    </div>
    <a class="button button--secondary" href="/plan">Browse and search</a>
  </div>
  <div class="filters-actions map-filter-bar">
    <% mapAvailabilityValues.forEach((value) => { %>
      <a class="button <%= filters.availability === value ? "" : "button--secondary" %>" href="/map/view?availability=<%= encodeURIComponent(value) %><%= filters.suburb ? `&suburb=${encodeURIComponent(filters.suburb)}` : "" %>"><%= value %></a>
    <% }) %>
  </div>
  <% if (suburbs.length) { %>
    <div class="tag-row map-suburb-row">
      <% suburbs.forEach((suburb) => { %>
        <a class="button <%= filters.suburb === suburb ? "" : "button--secondary" %>" href="/map/view?availability=<%= encodeURIComponent(filters.availability) %>&suburb=<%= encodeURIComponent(suburb) %>"><%= suburb %></a>
      <% }) %>
      <% if (filters.suburb) { %>
        <a class="button button--secondary" href="/map/view?availability=<%= encodeURIComponent(filters.availability) %>">Clear suburb</a>
      <% } %>
    </div>
  <% } %>
  <div id="map-view" class="map-view-canvas"></div>
</section>

<section class="section-block">
  <div class="section-heading section-heading--roomy">
    <div>
      <h2><span id="map-results-count"><%= mappablePlaces.length %></span> matching place<%= mappablePlaces.length === 1 ? "" : "s" %></h2>
      <p class="section-copy"><%= filters.availability %> results<%= filters.suburb ? ` in ${filters.suburb}` : "" %>.</p>
    </div>
  </div>

  <% if (mappablePlaces.length) { %>
    <div class="card-grid" id="map-result-cards">
      <% mappablePlaces.forEach((place) => { %>
        <div class="map-result-card" data-map-card data-slug="<%= place.slug %>" data-lat="<%= Number(place.latitude) %>" data-lng="<%= Number(place.longitude) %>">
          <%- include("partials/plan-card", { place, selectedDay: filters.day }) %>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-state">No mapped places are available right now.</p>
  <% } %>
</section>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script id="map-view-data" type="application/json"><%- JSON.stringify({
  places: mappablePlaces.map((place) => ({
    lat: Number(place.latitude),
    lng: Number(place.longitude),
    name: place.name,
    isOpen: Boolean(place.selectedAvailability && place.selectedAvailability.isOpen),
    slug: place.slug,
    suburb: place.suburb
  }))
}) %></script>
<script src="/map-view.js"></script>

<%- include("partials/footer") %>
