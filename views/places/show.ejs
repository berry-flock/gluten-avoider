<%- include("../partials/header") %>

<article class="place-detail">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Restaurant</p>
      <h1><%= place.name %></h1>
      <p class="place-card__suburb"><%= place.suburb %></p>
    </div>
    <div class="place-detail__meta">
      <span class="badge <%= badgeClass('status', place.status) %>"><%= formatStatus(place.status) %></span>
    </div>
  </div>

  <section class="detail-block detail-links detail-block--first">
    <h2>Links</h2>
    <div class="card-inline-links">
      <% if (place.website_url) { %>
        <a class="text-link" href="<%= place.website_url %>" target="_blank" rel="noreferrer">Website or menu</a>
      <% } %>
      <a class="text-link" href="<%= buildAppleMapsUrl(place) %>" target="_blank" rel="noreferrer">Apple Maps</a>
      <a class="text-link" href="<%= buildGoogleMapsUrl(place) %>" target="_blank" rel="noreferrer">Google Maps</a>
    </div>
  </section>

  <section class="detail-block">
    <h2>Address</h2>
    <% if (place.address) { %>
      <p><%= place.address %></p>
    <% } else { %>
      <p class="empty-state">No street address saved yet.</p>
    <% } %>
  </section>

  <% const menuItems = tagsByGroup(place.tags, "menu_items"); %>
  <% if (menuItems.length) { %>
    <section class="detail-block">
      <h2>Featured menu items</h2>
      <div class="tag-row">
        <% menuItems.forEach((tag) => { %>
          <a class="tag-pill tag-pill--link" href="/places?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (place.openSummary) { %>
    <section class="detail-block">
      <h2>Opening status</h2>
      <p class="hours-pill <%= isOpenNowClass(place.openSummary) %>"><%= place.openSummary.label %></p>
    </section>
  <% } %>

  <% if (place.openingHours && place.openingHours.length) { %>
    <section class="detail-block">
      <h2>Opening hours</h2>
      <dl class="hours-list">
        <% place.openingHours.forEach((hours) => { %>
          <div class="hours-row">
            <dt><%= dayLabels[hours.day_of_week] %></dt>
            <dd><%= formatHoursRange(hours) %></dd>
          </div>
        <% }) %>
      </dl>
    </section>
  <% } %>

  <% if (place.notes_public) { %>
    <section class="detail-block">
      <h2>Public notes</h2>
      <p><%= place.notes_public %></p>
    </section>
  <% } %>

  <% const categoryTags = tagsByGroup(place.tags, "category"); %>
  <% if (categoryTags.length) { %>
    <section class="detail-block">
      <h2>Category</h2>
      <div class="tag-row">
        <% categoryTags.forEach((tag) => { %>
          <a class="tag-pill tag-pill--link" href="/places?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% const glutenTags = tagsByGroup(place.tags, "gluten_features"); %>
  <% if (glutenTags.length) { %>
    <section class="detail-block">
      <h2>Gluten free features</h2>
      <div class="tag-row">
        <% glutenTags.forEach((tag) => { %>
          <a class="tag-pill tag-pill--link" href="/places?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>
</article>

<%- include("../partials/footer") %>
