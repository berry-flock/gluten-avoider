<%- include("../partials/header") %>

<article class="place-detail">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Place detail</p>
      <h1><%= place.name %></h1>
      <p class="place-card__suburb"><%= place.suburb %></p>
    </div>
  </div>

  <div class="place-detail__meta">
    <span class="badge <%= badgeClass('status', place.status) %>"><%= formatStatus(place.status) %></span>
  </div>

  <% if (place.openSummary) { %>
    <section class="detail-block">
      <h2>Opening status</h2>
      <p class="hours-pill <%= isOpenNowClass(place.openSummary) %>"><%= place.openSummary.label %></p>
    </section>
  <% } %>

  <section class="detail-block">
    <h2>Address</h2>
    <% if (place.address) { %>
      <p><%= place.address %></p>
    <% } else { %>
      <p class="empty-state">No location text saved yet.</p>
    <% } %>
    <% if (place.latitude !== null && place.latitude !== undefined && place.longitude !== null && place.longitude !== undefined && place.latitude !== "" && place.longitude !== "") { %>
      <p>Coordinates: <%= place.latitude %>, <%= place.longitude %></p>
    <% } %>
  </section>

  <% if (place.tags.length) { %>
    <section class="detail-block">
      <h2>Tags</h2>
      <div class="tag-row">
        <% place.tags.forEach((tag) => { %>
          <a class="tag-pill tag-pill--link" href="/places?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (place.notes_public) { %>
    <section class="detail-block">
      <h2>Notes</h2>
      <p><%= place.notes_public %></p>
    </section>
  <% } %>

  <% if (place.openingHours && place.openingHours.length) { %>
    <section class="detail-block">
      <h2>Opening hours</h2>
      <dl class="hours-list">
        <% place.openingHours.forEach((hours) => { %>
          <div class="hours-row">
            <dt><%= dayLabels[hours.day_of_week] %></dt>
            <dd><%= formatHoursRange(hours) %></dd>
          </div>
        <% }) %>
      </dl>
    </section>
  <% } %>

  <section class="detail-block detail-links">
    <h2>Links</h2>
    <% if (place.website_url) { %>
      <p><a class="text-link" href="<%= place.website_url %>" target="_blank" rel="noreferrer">Menu</a></p>
    <% } %>
    <% if (!place.website_url) { %>
      <p class="empty-state">No menu link saved yet.</p>
    <% } %>
  </section>
</article>

<%- include("../partials/footer") %>
