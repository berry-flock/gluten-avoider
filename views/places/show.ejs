<%- include("../partials/header") %>

<article class="place-detail">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Restaurant</p>
      <h1><%= place.name %></h1>
      <div class="place-detail__meta">
        <span class="place-detail__status"><%= formatStatus(place.status) %></span>
        <% if (currentAdmin) { %>
          <a class="text-link" href="/admin/places/<%= place.id %>/edit">Edit</a>
        <% } %>
      </div>
      <% if (place.notes_public) { %>
        <p class="place-detail__note"><%= place.notes_public %></p>
      <% } %>
      <% const categoryTags = tagsByGroup(place.tags, "category"); %>
      <% if (categoryTags.length) { %>
        <div class="tag-row place-detail__occasion-row">
          <% categoryTags.forEach((tag) => { %>
            <span class="occasion-chip"><%= tag.name %></span>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <% const menuItems = tagsByGroup(place.tags, "menu_items"); %>
  <% if (menuItems.length) { %>
    <section class="detail-block detail-block--first">
      <h2>On the menu</h2>
      <div class="tag-row place-detail__menu-row">
        <% menuItems.forEach((tag) => { %>
          <span class="menu-chip menu-chip--menu"><%= tag.name %></span>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="detail-block <%= !menuItems.length ? 'detail-block--first' : '' %>">
    <h2>Address</h2>
    <% if (place.address) { %>
      <a class="place-detail__address-link" href="<%= buildGoogleMapsUrl(place) %>" target="_blank" rel="noreferrer">
        <span><%= place.address %></span>
        <% if (place.suburb) { %>
          <span class="place-detail__address-suburb"><%= place.suburb %></span>
        <% } %>
      </a>
    <% } else { %>
      <p class="empty-state">No street address saved yet.</p>
    <% } %>
  </section>

  <% if (place.website_url) { %>
    <section class="detail-block detail-block--menu-link">
      <a class="button" href="<%= place.website_url %>" target="_blank" rel="noreferrer">Menu</a>
    </section>
  <% } %>

  <% if (place.openingHours && place.openingHours.length) { %>
    <section class="detail-block">
      <h2>Opening hours</h2>
      <% if (place.openSummary) { %>
        <%- include("../partials/open-status", { openSummary: place.openSummary, primaryClass: "nearby-status-line" }) %>
      <% } %>
      <dl class="hours-list">
        <% dayLabels.forEach((dayLabel, dayIndex) => { %>
          <div class="hours-row">
            <dt><%= dayLabel %></dt>
            <dd><%= formatHoursForDay(place.openingHours, dayIndex) %></dd>
          </div>
        <% }) %>
      </dl>
    </section>
  <% } %>

  <% const glutenTags = tagsByGroup(place.tags, "gluten_features"); %>
  <% if (glutenTags.length) { %>
    <section class="detail-block">
      <h2>Gluten free features</h2>
      <div class="tag-row">
        <% glutenTags.forEach((tag) => { %>
          <a class="tag-pill tag-pill--link" href="/plan?tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>
</article>

<%- include("../partials/footer") %>
