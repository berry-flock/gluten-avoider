<% const assetVersion = "20260405-2"; %>
<% const extraHead = `<link rel="stylesheet" href="/leaflet.css?v=${assetVersion}" />
<style>
  .leaflet-container img.leaflet-tile { mix-blend-mode: normal; }
</style>`; %>
<%- include("partials/header") %>

<% if (!location.hasCoordinates) { %>
  <section class="section-block">
    <form class="filters-panel" method="get" action="/nearby">
      <input type="hidden" id="nearby-lat-input" name="lat" value="<%= location.latitude ?? "" %>" />
      <input type="hidden" id="nearby-lng-input" name="lng" value="<%= location.longitude ?? "" %>" />
      <div class="filters-actions">
        <button class="button" type="button" id="nearby-use-location">Try location again</button>
      </div>
      <p class="empty-state" id="nearby-location-help">I don't know where you are. You might need to enable location services in your Safari settings. Or search manually below.</p>
      <div class="compact-search-form">
        <input id="nearby-search" type="text" name="search" value="<%= filters.search %>" placeholder="Search places, suburbs, or notes" />
        <button class="button button--secondary" type="submit">Search</button>
      </div>
    </form>
  </section>
<% } else { %>
  <section class="nearby-layout">
    <div class="section-block nearby-results-panel">
      <div class="filters-actions nearby-meal-switcher">
        <a class="button <%= !filters.meal ? "" : "button--secondary" %>" href="/nearby?lat=<%= encodeURIComponent(location.latitude) %>&lng=<%= encodeURIComponent(location.longitude) %><%= filters.search ? `&search=${encodeURIComponent(filters.search)}` : "" %>">Open</a>
        <a class="button <%= filters.meal === "lunch" ? "" : "button--secondary" %>" href="/nearby?lat=<%= encodeURIComponent(location.latitude) %>&lng=<%= encodeURIComponent(location.longitude) %>&meal=lunch<%= filters.search ? `&search=${encodeURIComponent(filters.search)}` : "" %>">Lunch</a>
        <a class="button <%= filters.meal === "dinner" ? "" : "button--secondary" %>" href="/nearby?lat=<%= encodeURIComponent(location.latitude) %>&lng=<%= encodeURIComponent(location.longitude) %>&meal=dinner<%= filters.search ? `&search=${encodeURIComponent(filters.search)}` : "" %>">Dinner</a>
      </div>
      <div class="section-heading section-heading--roomy">
        <div>
          <h2><span class="module-icon module-icon--pink"></span><%= places.length %> nearby place<%= places.length === 1 ? "" : "s" %></h2>
        </div>
      </div>

      <% if (places.length) { %>
        <div class="nearby-results-list">
          <% places.forEach((place) => { %>
            <%- include("partials/nearby-card", { place, location }) %>
          <% }) %>
        </div>
      <% } else { %>
        <p class="empty-state">No nearby places matched that search right now.</p>
      <% } %>
    </div>

    <section class="section-block nearby-refine-panel">
      <form class="filters-panel" method="get" action="/nearby">
        <input type="hidden" id="nearby-lat-input" name="lat" value="<%= location.latitude ?? "" %>" />
        <input type="hidden" id="nearby-lng-input" name="lng" value="<%= location.longitude ?? "" %>" />
        <input type="hidden" name="meal" value="<%= filters.meal %>" />
        <div class="compact-search-form">
          <input id="nearby-search" type="text" name="search" value="<%= filters.search %>" placeholder="Search places, suburbs, or notes" />
          <button class="button" type="submit">Search</button>
        </div>
        <div class="filters-actions">
          <a class="button button--secondary" href="/nearby">Reset</a>
        </div>
      </form>
    </section>

    <div class="section-block nearby-map-panel">
      <div class="section-heading section-heading--roomy">
        <h2><span class="module-icon module-icon--sky"></span>Map</h2>
      </div>
      <div id="nearby-map" class="nearby-map"></div>
    </div>
  </section>
<% } %>

<% if (location.hasCoordinates) { %>
  <script src="/leaflet.js?v=<%= assetVersion %>"></script>
  <script id="nearby-map-data" type="application/json"><%- JSON.stringify({
    userLocation: {
      lat: location.latitude,
      lng: location.longitude
    },
    places: places.map((place) => ({
      lat: Number(place.latitude),
      lng: Number(place.longitude),
      name: place.name,
      slug: place.slug,
      suburb: place.suburb,
      distanceKm: Number(place.distance_km.toFixed(1))
    }))
  }) %></script>
<% } %>
<script src="/nearby.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer") %>
