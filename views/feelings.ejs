<%- include("partials/header") %>

<section class="section-block feelings-panel" id="feelings-panel">
  <div class="feelings-pillbox-wrap">
    <h1 class="feelings-pillbox"><span class="module-icon module-icon--peach"></span>Food Feelings</h1>
  </div>

  <div class="filters-actions nearby-meal-switcher feelings-availability-switcher">
    <button class="button <%= feelingsAvailability === "open" ? "" : "button--secondary" %>" type="button" data-feelings-availability="open">Open</button>
    <button class="button <%= feelingsAvailability === "lunch" ? "" : "button--secondary" %>" type="button" data-feelings-availability="lunch">Lunch</button>
    <button class="button <%= feelingsAvailability === "dinner" ? "" : "button--secondary" %>" type="button" data-feelings-availability="dinner">Dinner</button>
  </div>

  <div class="feelings-stage" id="feelings-stage">
    <div class="feelings-stage__orb" aria-hidden="true"></div>
    <div class="feelings-stage__chips" id="feelings-menu-tags"></div>
  </div>

  <div class="feelings-stage__actions">
    <button class="button" type="button" id="feelings-refresh">SHUFFLE</button>
    <button class="button button--secondary" type="button" id="feelings-vibe-toggle">It's more the vibe...</button>
  </div>

  <div id="feelings-results-slot-food"></div>
</section>

<section class="section-block feelings-vibe-panel">
  <div class="section-heading">
    <div>
      <h2>Vibe selector</h2>
    </div>
  </div>

  <% if (categoryTagGroup && categoryTagGroup.tags.length) { %>
    <div class="tag-row feelings-vibe-tags" id="feelings-occasion-tags"></div>
    <p class="empty-state feelings-vibe-empty" id="feelings-vibe-empty" hidden>No vibe tags match this food feeling right now.</p>
  <% } %>

  <div id="feelings-results-slot-vibe"></div>
</section>

<section class="feelings-results-block" id="feelings-results-block">
  <div class="section-heading section-heading--roomy">
    <div>
      <h2><span id="feelings-results-count"><%= places.length %></span> restaurants</h2>
      <p class="section-copy" id="feelings-results-copy">Pick a craving, or skip straight to the vibe.</p>
    </div>
  </div>

  <div class="card-grid" id="feelings-results"></div>
</section>

<script id="feelings-data" type="application/json"><%- JSON.stringify({
  initialAvailability: feelingsAvailability,
  initialFoodSlug,
  initialMode,
  menuTags: (foodFeelingTags || []).map((tag) => ({
    name: tag.name,
    slug: tag.slug
  })),
  occasionTags: (categoryTagGroup?.tags || []).map((tag) => ({
    name: tag.name,
    slug: tag.slug
  })),
  places: places.map((place) => ({
    menuUrl: place.website_url || "",
    menuItems: (place.tags || [])
      .filter((tag) => tag.tag_group === "menu_items")
      .map((tag) => ({ name: tag.name, slug: tag.slug })),
    name: place.name,
    occasionTags: (place.tags || [])
      .filter((tag) => tag.tag_group === "category")
      .map((tag) => ({ name: tag.name, slug: tag.slug })),
    availabilityByMode: place.availabilityByMode || { open: false, lunch: false, dinner: false },
    latitude: place.latitude === null || place.latitude === "" ? null : Number(place.latitude),
    longitude: place.longitude === null || place.longitude === "" ? null : Number(place.longitude),
    slug: place.slug,
    sortIndex: place.sort_index || 0,
    suburb: place.suburb || "",
    summaryByMode: place.summaryByMode || {}
  }))
}) %></script>
<script src="/feelings.js?v=20260406-1"></script>

<%- include("partials/footer") %>
