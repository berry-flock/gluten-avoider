<article class="place-card nearby-card">
  <div class="place-card__top">
    <div>
      <h3 class="place-card__title">
        <a href="/places/<%= place.slug %>"><%= place.name %></a>
      </h3>
      <p class="place-card__suburb"><%= place.suburb %></p>
    </div>
    <p class="nearby-distance"><%= place.distance_km.toFixed(1) %> km</p>
  </div>

  <div class="place-card__badges">
    <span class="badge <%= badgeClass('status', place.status) %>"><%= formatStatus(place.status) %></span>
  </div>

  <% if (place.openSummary) { %>
    <p class="hours-pill <%= isOpenNowClass(place.openSummary) %>"><%= place.openSummary.label %></p>
  <% } %>

  <% const menuItems = tagsByGroup(place.tags, "menu_items"); %>
  <% if (menuItems.length) { %>
    <p class="place-card__excerpt"><strong>Featured menu items:</strong> <%= menuItems.slice(0, 3).map((tag) => tag.name).join(", ") %></p>
  <% } %>

  <% if (menuItems.length) { %>
    <div class="tag-row">
      <% menuItems.slice(0, 5).forEach((tag) => { %>
        <a class="tag-pill tag-pill--link" href="/nearby?lat=<%= encodeURIComponent(location.latitude) %>&lng=<%= encodeURIComponent(location.longitude) %>&tags=<%= encodeURIComponent(tag.slug) %>"><%= tag.name %></a>
      <% }) %>
    </div>
  <% } %>

  <div class="card-inline-links">
    <a class="text-link" href="/places/<%= place.slug %>">Open place page</a>
    <% if (place.website_url) { %>
      <a class="text-link" href="<%= place.website_url %>" target="_blank" rel="noreferrer">Full menu</a>
    <% } %>
  </div>
</article>
